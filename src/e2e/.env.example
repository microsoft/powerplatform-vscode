# Power Platform test environment configuration for E2E tests
# Copy this file to .env and fill in your test environment values

# Required: Power Platform test org URL
PP_TEST_ORG_URL=https://your-org.crm.dynamics.com

# Required: Test site IDs
PP_TEST_WEBSITE_ID=
PP_TEST_WEBSITE_PREVIEW_ID=
PP_TEST_ENV_ID=
PP_TEST_ORG_ID=
PP_TEST_TENANT_ID=

# Required: Test account credentials
PP_TEST_USERNAME=
PP_TEST_PASSWORD=

# Optional: Additional site configuration
PP_TEST_WEBSITE_NAME=Test Site
PP_TEST_WEBSITE_PREVIEW_URL=
PP_TEST_ENTITY_ID=
PP_TEST_GEO=WUS
PP_TEST_ORG_GEO=US
PP_TEST_SITE_VISIBILITY=public
PP_TEST_REGION=test
PP_TEST_SKU=Production
