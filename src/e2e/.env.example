# Power Platform E2E test configuration
# Copy this file to .env and fill in your values

# Required: Full VS Code Web URL
# Copy from your browser when editing a Power Pages site in VS Code Web.
# All site params (org, tenant, site IDs) are embedded in the URL.
PP_TEST_VSCODE_URL=

# Required: Test account credentials
PP_TEST_USERNAME=
PP_TEST_PASSWORD=
